root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{h,cpp}]
indent_style = tab
indent_size = 4
tab_width = 4

[*.{vcxproj,filters,props,sln}]
indent_style = tab
indent_size = 2
tab_width = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
