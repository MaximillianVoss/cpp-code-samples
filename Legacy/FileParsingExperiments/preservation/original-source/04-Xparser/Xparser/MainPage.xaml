<Page
    x:Class="Xparser.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Xparser"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#FF1489B5">
        <Grid.RowDefinitions>
            <RowDefinition Height="79*"/>
            <RowDefinition Height="600*"/>
            <RowDefinition Height="89*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="679*"/>
            <ColumnDefinition Width="687*"/>
        </Grid.ColumnDefinitions>
        <Button Content="Open file" HorizontalAlignment="Left" Margin="22,0,0,22" VerticalAlignment="Bottom" Height="60" Width="181" Grid.Row="2" Click="Button_Click"/>
        <RichEditBox x:Name="FileContentBlock" Margin="10,30,10,10" Grid.Row="1" FontSize="16" FontWeight="SemiLight" SelectionHighlightColor="#FF1489B5" TextChanged="FileContentBlock_TextChanged"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" Text="File preview" VerticalAlignment="Top" Height="59" Width="296" FontSize="54" FontFamily="Segoe UI Light"/>
        <ListBox x:Name="WordsList" Grid.Column="1" Margin="10,30,0,10" Grid.Row="1" HorizontalAlignment="Left" Width="254"/>
        <ListBox Grid.Column="1" HorizontalAlignment="Left" Margin="279,30,0,10" Grid.Row="1" Width="254"/>
        <TextBlock x:Name="FileNameLabel" Margin="10,0,358,0" TextWrapping="Wrap" Grid.Row="1" SelectionChanged="FileNameLabel_SelectionChanged" FontSize="18" FontFamily="Segoe UI" Height="25" VerticalAlignment="Top"/>

    </Grid>
</Page>
