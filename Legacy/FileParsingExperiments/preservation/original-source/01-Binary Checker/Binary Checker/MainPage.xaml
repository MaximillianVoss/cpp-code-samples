    xmlns:local="using:Binary_Checker"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Button x:Name="OpenBtn" Content="Button" HorizontalAlignment="Left" Margin="7,0,0,7" VerticalAlignment="Bottom" Width="195" Click="Button_Click" Height="74"/>
        <ListBox x:Name="FilesList" HorizontalAlignment="Left" Margin="10,10,0,83" Width="524"/>

    </Grid>
</Page>
